{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/go_fmt_lint.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/markdown_lint.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "modern-go-guidelines@goland-claude-marketplace": true
  }
}
