{
  "name": "k3s API Server Load Balancer",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:UTC}"
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    }
  },

  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--network=host"
  ],

  "remoteUser": "dev",

  "mounts": [
    "source=claude-code-config-${devcontainerId},target=/home/dev/.claude,type=volume",
    "source=${localEnv:HOME}/.claude/rules,target=/home/dev/.claude/rules,type=bind,readonly",
    "source=${localEnv:HOME}/.claude/skills,target=/home/dev/.claude/skills,type=bind,readonly",
    "source=${localEnv:HOME}/.claude/settings.json,target=/home/dev/.claude/settings.json,type=bind,readonly"
  ],

  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "CLAUDE_CONFIG_DIR": "/home/dev/.claude"
  },

  "customizations": {
    "jetbrains": {
      "backend": "IntelliJ",
      "plugins": [
        "com.intellij.kubernetes",
        "Docker"
      ]
    }
  },

  "onCreateCommand": "sudo chown dev:dev /home/dev/.claude && docker network create -d=bridge --subnet=172.19.0.0/24 kind || true",
  "postStartCommand": "sudo /usr/local/bin/init-firewall.sh",
  "waitFor": "postStartCommand"
}
